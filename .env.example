# ShortsForge Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env!

# --- LLM Provider (BYOK) ---
OPENAI_API_KEY=your-openai-api-key-here
# OR Azure OpenAI:
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_KEY=your-azure-openai-key-here
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Microsoft Foundry IQ (required for grounded story/script generation) ---
AZURE_FOUNDRY_ENDPOINT=https://your-foundry-endpoint.azure.com/
AZURE_FOUNDRY_KEY=your-foundry-api-key-here

# --- ElevenLabs TTS ---
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# --- YouTube Publishing ---
YOUTUBE_CLIENT_SECRET_PATH=/path/to/your/client_secret.json

# --- Whisper Model ---
SHORTSFORGE_WHISPER_MODEL=base.en

# --- Optional limits ---
# SHORTSFORGE_MAX_INPUT_SIZE_GB=2
# SHORTSFORGE_MAX_INPUT_DURATION_HOURS=4
# SHORTSFORGE_OUTPUT_CAP_GB=5
